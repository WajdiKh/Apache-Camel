@PostMapping("/validate")
public String validatePayment() {

    String xml = """
        <payment>
            <id>123</id>
            <amount>100</amount>
        </payment>
        """;

    producerTemplate.sendBody("direct:validatePayment", xml);

    return "Validation sent";
}

@PostMapping("/xml-routing/{amount}")
public String testXmlRouting(@PathVariable String amount) {

    String xml = """
        <payment>
            <id>PAY-001</id>
            <amount>%s</amount>
        </payment>
        """.formatted(amount);

    producerTemplate.sendBody("direct:xmlRouting", xml);

    return "XML routing sent";
}